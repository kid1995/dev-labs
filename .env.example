# Dev-Labs Environment Configuration
# Copy to .env and adjust for your machine:
#   cp .env.example .env

# --- Java ---
# Auto-detected if not set. Override if multiple JDKs installed.
# JAVA_HOME=/path/to/jdk-21

# --- Source paths ---
# Path to shared Java libraries (jwt-adapter, elpa4-shared-lib).
# Default: ../java_libs (relative to dev-labs/)
# JAVA_LIBS_DIR=/path/to/java_libs

# Path to elpa-elpa4 deploy repo content (for setup-deploy-repo.sh).
# Default: ../combine-hint/elpa-elpa4
# DEPLOY_REPO_SOURCE=/path/to/elpa-elpa4

# --- Docker Compose profiles ---
# Include Signal Iduna UI components (Storybook + Lab Guide).
# Requires src/design-system/ and docs/lab-guide/ directories.
# Uncomment to enable:
# COMPOSE_PROFILES=si-ui

# --- PostgreSQL ---
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_password

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
